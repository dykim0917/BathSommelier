{
  "name": "getbathtime",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "trip:theme": "node scripts/trip_theme_agent.mjs",
    "trip:content": "node scripts/trip_content_agent.mjs",
    "trip:image": "node scripts/trip_image_agent.mjs --input-dir output",
    "screenshots:ui": "node scripts/capture_ui_screenshots.mjs",
    "export:web": "expo export --platform web",
    "catalog:research": "node scripts/catalog_research_agent.mjs",
    "catalog:collect:browser": "node scripts/catalog_browser_collector.mjs",
    "catalog:proposal": "node scripts/catalog_normalize_agent.mjs",
    "catalog:seed:export": "node scripts/export_catalog_research_seed.mjs",
    "catalog:seed:export:postgres": "node scripts/export_catalog_research_seed_postgres.mjs",
    "content:seed:export:postgres": "node scripts/export_content_seed_postgres.mjs",
    "catalog:api:mock": "node scripts/mock_catalog_api.mjs",
    "content:api:mock": "node scripts/mock_content_api.mjs",
    "test": "jest",
    "test:scenario:print": "jest src/engine/__tests__/scenario_output.test.ts --runInBand",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "^5.0.1",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.33",
    "expo-audio": "~1.1.1",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-navigation-bar": "~5.0.10",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "lottie-react-native": "~7.3.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "playwright": "^1.59.1",
    "react-native-svg-transformer": "^1.5.3",
    "react-test-renderer": "19.1.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  },
  "private": true
}
